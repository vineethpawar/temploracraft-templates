{
  "version": 1,
  "domain": "resume",
  "slug": "broadsheet",
  "name": "Broadsheet",
  "description": "Editorial serif with a sans/serif contrast. Newsreader body under IBM Plex Sans small-caps section titles, italic tagline, ink-navy name. Feels like a masthead, not a form.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "Newsreader",    "weights": [400, 600, 700], "source": "google" },
    { "family": "IBM Plex Sans", "weights": [400, 500, 600], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 28,
    "padding": [72, 76, 72, 76],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-vertical",
        "gap": 8,
        "children": [
          {
            "id": "header-name",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "fullName",
            "fallback": "Your name",
            "style": {
              "fontFamily": "Newsreader",
              "fontWeight": 600,
              "fontSize": 36,
              "lineHeight": 1.05,
              "letterSpacing": -0.8,
              "color": "#1F2B4A",
              "align": "left"
            }
          },
          {
            "id": "header-headline",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "headline",
            "visibleIf": "headline",
            "style": {
              "fontFamily": "Newsreader",
              "fontWeight": 400,
              "fontSize": 14,
              "lineHeight": 1.4,
              "color": "#4A4239",
              "align": "left"
            }
          },
          {
            "id": "header-contact",
            "type": "text",
            "x": 0, "y": 0,
            "content": "{{email}}   ·   {{phone}}   ·   {{location}}",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#6B635B",
              "align": "left",
              "letterSpacing": 0.4
            }
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "Newsreader",
              "fontWeight": 400,
              "fontSize": 13,
              "lineHeight": 1.7,
              "color": "#1A1A1A",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 16,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Experience",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 600,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#1A1A1A",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 18,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 4,
              "children": [
                {
                  "id": "experience-item-role",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{title}}",
                  "style": {
                    "fontFamily": "Newsreader",
                    "fontWeight": 600,
                    "fontSize": 14,
                    "lineHeight": 1.3,
                    "color": "#1A1A1A",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-meta",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{company}}  ·  {{location}}  ·  {{startDate}} — {{endDate}}",
                  "style": {
                    "fontFamily": "IBM Plex Sans",
                    "fontWeight": 500,
                    "fontSize": 10,
                    "lineHeight": 1.4,
                    "color": "#4A4239",
                    "align": "left",
                    "letterSpacing": 0.4,
                    "transform": "uppercase"
                  }
                },
                {
                  "id": "experience-item-bullets",
                  "type": "bullet-list",
                  "x": 0, "y": 0,
                  "bind": "bullets",
                  "visibleIf": "bullets",
                  "layout": "vertical",
                  "bulletChar": "»",
                  "gap": 3,
                  "style": {
                    "fontFamily": "Newsreader",
                    "fontWeight": 400,
                    "fontSize": 12,
                    "lineHeight": 1.65,
                    "color": "#1A1A1A",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Education",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 600,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#1A1A1A",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 12,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 2,
              "children": [
                {
                  "id": "education-item-institution",
                  "type": "placeholder-text",
                  "x": 0, "y": 0,
                  "bind": "institution",
                  "fallback": "Institution",
                  "style": {
                    "fontFamily": "Newsreader",
                    "fontWeight": 600,
                    "fontSize": 13,
                    "lineHeight": 1.3,
                    "color": "#1A1A1A",
                    "align": "left"
                  }
                },
                {
                  "id": "education-item-meta",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{degree}}, {{field}}  ·  {{startYear}} — {{endYear}}",
                  "style": {
                    "fontFamily": "IBM Plex Sans",
                    "fontWeight": 500,
                    "fontSize": 10,
                    "lineHeight": 1.4,
                    "color": "#4A4239",
                    "align": "left",
                    "letterSpacing": 0.4,
                    "transform": "uppercase"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Skills",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 600,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#1A1A1A",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  ·  ",
            "style": {
              "fontFamily": "Newsreader",
              "fontWeight": 400,
              "fontSize": 12,
              "lineHeight": 1.7,
              "color": "#1A1A1A",
              "align": "left"
            }
          }
        ]
      }
    ]
  }
}
