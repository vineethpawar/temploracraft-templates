{
  "version": 1,
  "domain": "resume",
  "slug": "meridian",
  "name": "Meridian",
  "description": "Contemporary Manrope with a saturated teal accent. Heavy uppercase section titles, pipe-separated meta, bare-indent bullets. The polished mid-career workhorse — not designer, not corporate, just deliberate.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "Manrope", "weights": [400, 500, 600, 700], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 24,
    "padding": [72, 76, 72, 76],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-vertical",
        "gap": 6,
        "children": [
          {
            "id": "header-name",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "fullName",
            "fallback": "Your name",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 700,
              "fontSize": 30,
              "lineHeight": 1.1,
              "letterSpacing": -0.6,
              "color": "#1F2937",
              "align": "left"
            }
          },
          {
            "id": "header-headline",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "headline",
            "visibleIf": "headline",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 500,
              "fontSize": 13,
              "lineHeight": 1.4,
              "color": "#0E7C86",
              "align": "left"
            }
          },
          {
            "id": "header-contact",
            "type": "text",
            "x": 0, "y": 0,
            "content": "{{email}}  |  {{phone}}  |  {{location}}",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#6B7280",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 400,
              "fontSize": 12,
              "lineHeight": 1.65,
              "color": "#1F2937",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 14,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Experience",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 700,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#0E7C86",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 16,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 4,
              "children": [
                {
                  "id": "experience-item-role",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{title}}",
                  "style": {
                    "fontFamily": "Manrope",
                    "fontWeight": 600,
                    "fontSize": 13,
                    "lineHeight": 1.3,
                    "color": "#1F2937",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-meta",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{company}}  |  {{location}}  |  {{startDate}} — {{endDate}}",
                  "style": {
                    "fontFamily": "Manrope",
                    "fontWeight": 500,
                    "fontSize": 10.5,
                    "lineHeight": 1.4,
                    "color": "#6B7280",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-bullets",
                  "type": "bullet-list",
                  "x": 0, "y": 0,
                  "bind": "bullets",
                  "visibleIf": "bullets",
                  "layout": "vertical",
                  "bulletChar": " ",
                  "gap": 3,
                  "style": {
                    "fontFamily": "Manrope",
                    "fontWeight": 400,
                    "fontSize": 11.5,
                    "lineHeight": 1.6,
                    "color": "#1F2937",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Education",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 700,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#0E7C86",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 10,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 2,
              "children": [
                {
                  "id": "education-item-institution",
                  "type": "placeholder-text",
                  "x": 0, "y": 0,
                  "bind": "institution",
                  "fallback": "Institution",
                  "style": {
                    "fontFamily": "Manrope",
                    "fontWeight": 600,
                    "fontSize": 12.5,
                    "lineHeight": 1.3,
                    "color": "#1F2937",
                    "align": "left"
                  }
                },
                {
                  "id": "education-item-meta",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{degree}}, {{field}}  |  {{startYear}} — {{endYear}}",
                  "style": {
                    "fontFamily": "Manrope",
                    "fontWeight": 500,
                    "fontSize": 10.5,
                    "lineHeight": 1.4,
                    "color": "#6B7280",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Skills",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 700,
              "fontSize": 11,
              "lineHeight": 1.2,
              "letterSpacing": 2.4,
              "color": "#0E7C86",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  |  ",
            "style": {
              "fontFamily": "Manrope",
              "fontWeight": 500,
              "fontSize": 11.5,
              "lineHeight": 1.6,
              "color": "#1F2937",
              "align": "left"
            }
          }
        ]
      }
    ]
  }
}
