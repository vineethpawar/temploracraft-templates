{
  "version": 1,
  "domain": "resume",
  "slug": "zurich",
  "name": "Zurich",
  "description": "Swiss-grid single column with hairline rules and small-caps section headers. One typeface throughout — the discipline is the point. Reads like a specimen; parses like a spreadsheet.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "Inter Tight", "weights": [400, 500, 600], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 26,
    "padding": [72, 76, 72, 76],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-horizontal",
        "justify": "between",
        "align": "baseline",
        "gap": 24,
        "children": [
          {
            "id": "header-left",
            "type": "section",
            "x": 0, "y": 0,
            "layout": "flow-vertical",
            "gap": 4,
            "children": [
              {
                "id": "header-name",
                "type": "placeholder-text",
                "x": 0, "y": 0,
                "bind": "fullName",
                "fallback": "Your name",
                "style": {
                  "fontFamily": "Inter Tight",
                  "fontWeight": 500,
                  "fontSize": 28,
                  "lineHeight": 1.1,
                  "letterSpacing": -0.6,
                  "color": "#111111",
                  "align": "left"
                }
              },
              {
                "id": "header-headline",
                "type": "placeholder-text",
                "x": 0, "y": 0,
                "bind": "headline",
                "visibleIf": "headline",
                "style": {
                  "fontFamily": "Inter Tight",
                  "fontWeight": 400,
                  "fontSize": 11,
                  "lineHeight": 1.4,
                  "letterSpacing": 2.4,
                  "color": "#3F3F3F",
                  "align": "left",
                  "transform": "uppercase"
                }
              }
            ]
          },
          {
            "id": "header-right",
            "type": "section",
            "x": 0, "y": 0,
            "layout": "flow-vertical",
            "align": "end",
            "gap": 2,
            "children": [
              {
                "id": "header-email",
                "type": "placeholder-text",
                "x": 0, "y": 0,
                "bind": "email",
                "visibleIf": "email",
                "style": {
                  "fontFamily": "Inter Tight",
                  "fontWeight": 400,
                  "fontSize": 11,
                  "lineHeight": 1.45,
                  "color": "#111111",
                  "align": "right"
                }
              },
              {
                "id": "header-phone",
                "type": "placeholder-text",
                "x": 0, "y": 0,
                "bind": "phone",
                "visibleIf": "phone",
                "style": {
                  "fontFamily": "Inter Tight",
                  "fontWeight": 400,
                  "fontSize": 11,
                  "lineHeight": 1.45,
                  "color": "#111111",
                  "align": "right"
                }
              },
              {
                "id": "header-location",
                "type": "placeholder-text",
                "x": 0, "y": 0,
                "bind": "location",
                "visibleIf": "location",
                "style": {
                  "fontFamily": "Inter Tight",
                  "fontWeight": 400,
                  "fontSize": 11,
                  "lineHeight": 1.45,
                  "color": "#3F3F3F",
                  "align": "right"
                }
              }
            ]
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-rule",
            "type": "divider",
            "x": 0, "y": 0,
            "color": "#111111",
            "thickness": 1
          },
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "Inter Tight",
              "fontWeight": 400,
              "fontSize": 12,
              "lineHeight": 1.6,
              "color": "#1F1F1F",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 14,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Experience",
            "style": {
              "fontFamily": "Inter Tight",
              "fontWeight": 600,
              "fontSize": 10,
              "lineHeight": 1.2,
              "letterSpacing": 2.8,
              "color": "#111111",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "experience-rule",
            "type": "divider",
            "x": 0, "y": 0,
            "color": "#111111",
            "thickness": 1
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 16,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 4,
              "children": [
                {
                  "id": "experience-item-line1",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-horizontal",
                  "justify": "between",
                  "align": "baseline",
                  "gap": 12,
                  "children": [
                    {
                      "id": "experience-item-role",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{title}}",
                      "style": {
                        "fontFamily": "Inter Tight",
                        "fontWeight": 600,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#111111",
                        "align": "left"
                      }
                    },
                    {
                      "id": "experience-item-dates",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{startDate}} — {{endDate}}",
                      "style": {
                        "fontFamily": "Inter Tight",
                        "fontWeight": 400,
                        "fontSize": 11,
                        "lineHeight": 1.3,
                        "color": "#3F3F3F",
                        "align": "right"
                      }
                    }
                  ]
                },
                {
                  "id": "experience-item-company",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{company}}  ·  {{location}}",
                  "style": {
                    "fontFamily": "Inter Tight",
                    "fontWeight": 400,
                    "fontSize": 11,
                    "lineHeight": 1.4,
                    "color": "#3F3F3F",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-bullets",
                  "type": "bullet-list",
                  "x": 0, "y": 0,
                  "bind": "bullets",
                  "visibleIf": "bullets",
                  "layout": "vertical",
                  "bulletChar": "—",
                  "gap": 2,
                  "style": {
                    "fontFamily": "Inter Tight",
                    "fontWeight": 400,
                    "fontSize": 11.5,
                    "lineHeight": 1.55,
                    "color": "#1F1F1F",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 14,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Education",
            "style": {
              "fontFamily": "Inter Tight",
              "fontWeight": 600,
              "fontSize": 10,
              "lineHeight": 1.2,
              "letterSpacing": 2.8,
              "color": "#111111",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "education-rule",
            "type": "divider",
            "x": 0, "y": 0,
            "color": "#111111",
            "thickness": 1
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 10,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-horizontal",
              "justify": "between",
              "align": "baseline",
              "gap": 12,
              "children": [
                {
                  "id": "education-item-left",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-vertical",
                  "gap": 2,
                  "children": [
                    {
                      "id": "education-item-institution",
                      "type": "placeholder-text",
                      "x": 0, "y": 0,
                      "bind": "institution",
                      "fallback": "Institution",
                      "style": {
                        "fontFamily": "Inter Tight",
                        "fontWeight": 600,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#111111",
                        "align": "left"
                      }
                    },
                    {
                      "id": "education-item-degree",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{degree}}, {{field}}",
                      "style": {
                        "fontFamily": "Inter Tight",
                        "fontWeight": 400,
                        "fontSize": 11,
                        "lineHeight": 1.4,
                        "color": "#3F3F3F",
                        "align": "left"
                      }
                    }
                  ]
                },
                {
                  "id": "education-item-dates",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{startYear}} — {{endYear}}",
                  "style": {
                    "fontFamily": "Inter Tight",
                    "fontWeight": 400,
                    "fontSize": 11,
                    "lineHeight": 1.3,
                    "color": "#3F3F3F",
                    "align": "right"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Skills",
            "style": {
              "fontFamily": "Inter Tight",
              "fontWeight": 600,
              "fontSize": 10,
              "lineHeight": 1.2,
              "letterSpacing": 2.8,
              "color": "#111111",
              "align": "left",
              "transform": "uppercase"
            }
          },
          {
            "id": "skills-rule",
            "type": "divider",
            "x": 0, "y": 0,
            "color": "#111111",
            "thickness": 1
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  ·  ",
            "style": {
              "fontFamily": "Inter Tight",
              "fontWeight": 400,
              "fontSize": 11.5,
              "lineHeight": 1.6,
              "color": "#1F1F1F",
              "align": "left"
            }
          }
        ]
      }
    ]
  }
}
