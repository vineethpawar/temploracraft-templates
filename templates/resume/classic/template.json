{
  "version": 1,
  "domain": "resume",
  "slug": "classic",
  "name": "Classic",
  "description": "Centered serif header, traditional resume rhythm. Playfair Display for the name + section titles, IBM Plex Serif for body copy. Reads well printed or ATS-scanned.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "premium": true,
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "Playfair Display", "weights": [400, 600, 700], "source": "google" },
    { "family": "IBM Plex Serif", "weights": [400, 500, 700], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 28,
    "padding": [64, 72, 64, 72],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-vertical",
        "gap": 6,
        "align": "center",
        "children": [
          {
            "id": "header-name",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "fullName",
            "fallback": "Your name",
            "style": {
              "fontFamily": "Playfair Display",
              "fontWeight": 700,
              "fontSize": 42,
              "lineHeight": 1.05,
              "letterSpacing": -0.4,
              "color": "#1A1613",
              "align": "center"
            }
          },
          {
            "id": "header-headline",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "headline",
            "visibleIf": "headline",
            "style": {
              "fontFamily": "IBM Plex Serif",
              "fontWeight": 400,
              "fontSize": 14,
              "lineHeight": 1.4,
              "color": "#4A4239",
              "align": "center",
              "transform": "uppercase",
              "letterSpacing": 3
            }
          },
          {
            "id": "header-contact",
            "type": "text",
            "x": 0, "y": 0,
            "content": "{{email}}  ·  {{phone}}  ·  {{location}}",
            "style": {
              "fontFamily": "IBM Plex Serif",
              "fontWeight": 400,
              "fontSize": 12,
              "lineHeight": 1.5,
              "color": "#6B635B",
              "align": "center"
            }
          },
          {
            "id": "header-rule",
            "type": "divider",
            "x": 0, "y": 0,
            "color": "#1A1613",
            "thickness": 1
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "IBM Plex Serif",
              "fontWeight": 400,
              "fontSize": 13,
              "lineHeight": 1.65,
              "color": "#1A1613",
              "align": "center"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 16,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Experience",
            "style": {
              "fontFamily": "Playfair Display",
              "fontWeight": 600,
              "fontSize": 15,
              "lineHeight": 1.2,
              "letterSpacing": 2,
              "color": "#1A1613",
              "align": "center",
              "transform": "uppercase"
            }
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 18,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 6,
              "children": [
                {
                  "id": "experience-item-header",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-horizontal",
                  "justify": "between",
                  "align": "baseline",
                  "gap": 12,
                  "children": [
                    {
                      "id": "experience-item-title",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{title}}",
                      "style": {
                        "fontFamily": "IBM Plex Serif",
                        "fontWeight": 700,
                        "fontSize": 14,
                        "lineHeight": 1.3,
                        "color": "#1A1613",
                        "align": "left"
                      }
                    },
                    {
                      "id": "experience-item-dates",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{startDate}} — {{endDate}}",
                      "style": {
                        "fontFamily": "IBM Plex Serif",
                        "fontWeight": 400,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#6B635B",
                        "align": "right"
                      }
                    }
                  ]
                },
                {
                  "id": "experience-item-company",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{company}}  ·  {{location}}",
                  "style": {
                    "fontFamily": "IBM Plex Serif",
                    "fontWeight": 400,
                    "fontSize": 12,
                    "lineHeight": 1.3,
                    "color": "#4A4239",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-bullets",
                  "type": "bullet-list",
                  "x": 0, "y": 0,
                  "bind": "bullets",
                  "visibleIf": "bullets",
                  "layout": "vertical",
                  "bulletChar": "—",
                  "gap": 2,
                  "style": {
                    "fontFamily": "IBM Plex Serif",
                    "fontWeight": 400,
                    "fontSize": 13,
                    "lineHeight": 1.6,
                    "color": "#1A1613",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Education",
            "style": {
              "fontFamily": "Playfair Display",
              "fontWeight": 600,
              "fontSize": 15,
              "lineHeight": 1.2,
              "letterSpacing": 2,
              "color": "#1A1613",
              "align": "center",
              "transform": "uppercase"
            }
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 10,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-horizontal",
              "justify": "between",
              "align": "baseline",
              "gap": 12,
              "children": [
                {
                  "id": "education-item-left",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-vertical",
                  "gap": 2,
                  "children": [
                    {
                      "id": "education-item-institution",
                      "type": "placeholder-text",
                      "x": 0, "y": 0,
                      "bind": "institution",
                      "fallback": "Institution",
                      "style": {
                        "fontFamily": "IBM Plex Serif",
                        "fontWeight": 700,
                        "fontSize": 14,
                        "lineHeight": 1.3,
                        "color": "#1A1613",
                        "align": "left"
                      }
                    },
                    {
                      "id": "education-item-degree",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{degree}}, {{field}}",
                      "style": {
                        "fontFamily": "IBM Plex Serif",
                        "fontWeight": 400,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#4A4239",
                        "align": "left"
                      }
                    }
                  ]
                },
                {
                  "id": "education-item-dates",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{startYear}} — {{endYear}}",
                  "style": {
                    "fontFamily": "IBM Plex Serif",
                    "fontWeight": 400,
                    "fontSize": 12,
                    "lineHeight": 1.3,
                    "color": "#6B635B",
                    "align": "right"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "Skills",
            "style": {
              "fontFamily": "Playfair Display",
              "fontWeight": 600,
              "fontSize": 15,
              "lineHeight": 1.2,
              "letterSpacing": 2,
              "color": "#1A1613",
              "align": "center",
              "transform": "uppercase"
            }
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  ·  ",
            "style": {
              "fontFamily": "IBM Plex Serif",
              "fontWeight": 400,
              "fontSize": 13,
              "lineHeight": 1.65,
              "color": "#1A1613",
              "align": "center"
            }
          }
        ]
      }
    ]
  }
}
