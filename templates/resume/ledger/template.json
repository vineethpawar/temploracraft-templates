{
  "version": 1,
  "domain": "resume",
  "slug": "ledger",
  "name": "Ledger",
  "description": "Academic long-form CV. Source Serif 4 body with a left-margin date rail — every entry reads as a scholarly chronology. Oxblood accent on the name, small-caps Source Sans section headers.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "Source Serif 4", "weights": [400, 600], "source": "google" },
    { "family": "Source Sans 3",  "weights": [400, 600], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 26,
    "padding": [72, 76, 72, 76],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-vertical",
        "gap": 4,
        "children": [
          {
            "id": "header-name",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "fullName",
            "fallback": "Your name",
            "style": {
              "fontFamily": "Source Serif 4",
              "fontWeight": 400,
              "fontSize": 28,
              "lineHeight": 1.1,
              "letterSpacing": -0.3,
              "color": "#7A1F1F",
              "align": "left"
            }
          },
          {
            "id": "header-headline",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "headline",
            "visibleIf": "headline",
            "style": {
              "fontFamily": "Source Serif 4",
              "fontWeight": 400,
              "fontSize": 13,
              "lineHeight": 1.5,
              "color": "#333333",
              "align": "left"
            }
          },
          {
            "id": "header-contact",
            "type": "text",
            "x": 0, "y": 0,
            "content": "{{email}}   ·   {{phone}}   ·   {{location}}",
            "style": {
              "fontFamily": "Source Sans 3",
              "fontWeight": 400,
              "fontSize": 10.5,
              "lineHeight": 1.6,
              "color": "#555555",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "Source Serif 4",
              "fontWeight": 400,
              "fontSize": 11.5,
              "lineHeight": 1.7,
              "color": "#222222",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 14,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "EXPERIENCE",
            "style": {
              "fontFamily": "Source Sans 3",
              "fontWeight": 600,
              "fontSize": 10.5,
              "lineHeight": 1.2,
              "letterSpacing": 2.2,
              "color": "#7A1F1F",
              "align": "left"
            }
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 14,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-horizontal",
              "gap": 18,
              "align": "start",
              "children": [
                {
                  "id": "experience-item-daterail",
                  "type": "section",
                  "x": 0, "y": 0,
                  "width": 92,
                  "layout": "flow-vertical",
                  "gap": 2,
                  "children": [
                    {
                      "id": "experience-item-dates",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{startDate}} — {{endDate}}",
                      "style": {
                        "fontFamily": "Source Sans 3",
                        "fontWeight": 400,
                        "fontSize": 10.5,
                        "lineHeight": 1.4,
                        "color": "#555555",
                        "align": "left"
                      }
                    }
                  ]
                },
                {
                  "id": "experience-item-content",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-vertical",
                  "gap": 4,
                  "children": [
                    {
                      "id": "experience-item-role",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{title}}",
                      "style": {
                        "fontFamily": "Source Serif 4",
                        "fontWeight": 600,
                        "fontSize": 13,
                        "lineHeight": 1.3,
                        "color": "#222222",
                        "align": "left"
                      }
                    },
                    {
                      "id": "experience-item-company",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{company}}  ·  {{location}}",
                      "style": {
                        "fontFamily": "Source Sans 3",
                        "fontWeight": 400,
                        "fontSize": 10.5,
                        "lineHeight": 1.4,
                        "color": "#555555",
                        "align": "left"
                      }
                    },
                    {
                      "id": "experience-item-bullets",
                      "type": "bullet-list",
                      "x": 0, "y": 0,
                      "bind": "bullets",
                      "visibleIf": "bullets",
                      "layout": "vertical",
                      "bulletChar": "•",
                      "gap": 2,
                      "style": {
                        "fontFamily": "Source Serif 4",
                        "fontWeight": 400,
                        "fontSize": 11,
                        "lineHeight": 1.6,
                        "color": "#222222",
                        "align": "left"
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "EDUCATION",
            "style": {
              "fontFamily": "Source Sans 3",
              "fontWeight": 600,
              "fontSize": 10.5,
              "lineHeight": 1.2,
              "letterSpacing": 2.2,
              "color": "#7A1F1F",
              "align": "left"
            }
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 10,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-horizontal",
              "gap": 18,
              "align": "start",
              "children": [
                {
                  "id": "education-item-daterail",
                  "type": "section",
                  "x": 0, "y": 0,
                  "width": 92,
                  "layout": "flow-vertical",
                  "children": [
                    {
                      "id": "education-item-dates",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{startYear}} — {{endYear}}",
                      "style": {
                        "fontFamily": "Source Sans 3",
                        "fontWeight": 400,
                        "fontSize": 10.5,
                        "lineHeight": 1.4,
                        "color": "#555555",
                        "align": "left"
                      }
                    }
                  ]
                },
                {
                  "id": "education-item-content",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-vertical",
                  "gap": 2,
                  "children": [
                    {
                      "id": "education-item-institution",
                      "type": "placeholder-text",
                      "x": 0, "y": 0,
                      "bind": "institution",
                      "fallback": "Institution",
                      "style": {
                        "fontFamily": "Source Serif 4",
                        "fontWeight": 600,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#222222",
                        "align": "left"
                      }
                    },
                    {
                      "id": "education-item-degree",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{degree}}, {{field}}",
                      "style": {
                        "fontFamily": "Source Sans 3",
                        "fontWeight": 400,
                        "fontSize": 10.5,
                        "lineHeight": 1.4,
                        "color": "#555555",
                        "align": "left"
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "SKILLS",
            "style": {
              "fontFamily": "Source Sans 3",
              "fontWeight": 600,
              "fontSize": 10.5,
              "lineHeight": 1.2,
              "letterSpacing": 2.2,
              "color": "#7A1F1F",
              "align": "left"
            }
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  ·  ",
            "style": {
              "fontFamily": "Source Serif 4",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.65,
              "color": "#222222",
              "align": "left"
            }
          }
        ]
      }
    ]
  }
}
