{
  "version": 1,
  "domain": "resume",
  "slug": "terminal",
  "name": "Terminal",
  "description": "Config-file resume for engineers. IBM Plex Sans body with JetBrains Mono section headers prefixed by `#`. Reads like a well-commented dotfile; parses like a resume.",
  "author": {
    "name": "Vineeth Pawar",
    "url": "https://vpawar.me",
    "githubUsername": "vineethpawar"
  },
  "license": "MIT",
  "page": { "width": 816, "height": 1056 },
  "fonts": [
    { "family": "IBM Plex Sans",  "weights": [400, 500, 600], "source": "google" },
    { "family": "JetBrains Mono", "weights": [400, 500, 600], "source": "google" }
  ],
  "root": {
    "id": "root",
    "type": "section",
    "x": 0, "y": 0,
    "label": "Page",
    "layout": "flow-vertical",
    "gap": 26,
    "padding": [64, 72, 72, 72],
    "children": [
      {
        "id": "header",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Header",
        "layout": "flow-vertical",
        "gap": 8,
        "children": [
          {
            "id": "header-name",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "fullName",
            "fallback": "your name",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 600,
              "fontSize": 30,
              "lineHeight": 1.1,
              "letterSpacing": -0.4,
              "color": "#111111",
              "align": "left"
            }
          },
          {
            "id": "header-meta-role",
            "type": "text",
            "x": 0, "y": 0,
            "content": "role    :  {{headline}}",
            "visibleIf": "headline",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#1F1F1F",
              "align": "left"
            }
          },
          {
            "id": "header-meta-email",
            "type": "text",
            "x": 0, "y": 0,
            "content": "email   :  {{email}}",
            "visibleIf": "email",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#1F1F1F",
              "align": "left"
            }
          },
          {
            "id": "header-meta-phone",
            "type": "text",
            "x": 0, "y": 0,
            "content": "phone   :  {{phone}}",
            "visibleIf": "phone",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#1F1F1F",
              "align": "left"
            }
          },
          {
            "id": "header-meta-loc",
            "type": "text",
            "x": 0, "y": 0,
            "content": "based   :  {{location}}",
            "visibleIf": "location",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.5,
              "color": "#1F1F1F",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "summary",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Summary",
        "layout": "flow-vertical",
        "gap": 8,
        "visibleIf": "summary",
        "children": [
          {
            "id": "summary-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "# summary",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 600,
              "fontSize": 12,
              "lineHeight": 1.3,
              "color": "#2F855A",
              "align": "left"
            }
          },
          {
            "id": "summary-body",
            "type": "placeholder-text",
            "x": 0, "y": 0,
            "bind": "summary",
            "style": {
              "fontFamily": "IBM Plex Sans",
              "fontWeight": 400,
              "fontSize": 12,
              "lineHeight": 1.6,
              "color": "#1F1F1F",
              "align": "left"
            }
          }
        ]
      },

      {
        "id": "experience",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Experience",
        "layout": "flow-vertical",
        "gap": 14,
        "visibleIf": "experience",
        "children": [
          {
            "id": "experience-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "# experience",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 600,
              "fontSize": 12,
              "lineHeight": 1.3,
              "color": "#2F855A",
              "align": "left"
            }
          },
          {
            "id": "experience-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "experience",
            "layout": "flow-vertical",
            "gap": 18,
            "template": {
              "id": "experience-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-vertical",
              "gap": 4,
              "children": [
                {
                  "id": "experience-item-line1",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-horizontal",
                  "justify": "between",
                  "align": "baseline",
                  "gap": 12,
                  "children": [
                    {
                      "id": "experience-item-role",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{title}}",
                      "style": {
                        "fontFamily": "IBM Plex Sans",
                        "fontWeight": 600,
                        "fontSize": 13,
                        "lineHeight": 1.3,
                        "color": "#111111",
                        "align": "left"
                      }
                    },
                    {
                      "id": "experience-item-dates",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "[{{startDate}} → {{endDate}}]",
                      "style": {
                        "fontFamily": "JetBrains Mono",
                        "fontWeight": 400,
                        "fontSize": 10.5,
                        "lineHeight": 1.3,
                        "color": "#2F855A",
                        "align": "right"
                      }
                    }
                  ]
                },
                {
                  "id": "experience-item-company",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "{{company}}  ·  {{location}}",
                  "style": {
                    "fontFamily": "IBM Plex Sans",
                    "fontWeight": 500,
                    "fontSize": 11,
                    "lineHeight": 1.4,
                    "color": "#3F3F3F",
                    "align": "left"
                  }
                },
                {
                  "id": "experience-item-bullets",
                  "type": "bullet-list",
                  "x": 0, "y": 0,
                  "bind": "bullets",
                  "visibleIf": "bullets",
                  "layout": "vertical",
                  "bulletChar": "▸",
                  "gap": 3,
                  "style": {
                    "fontFamily": "IBM Plex Sans",
                    "fontWeight": 400,
                    "fontSize": 11.5,
                    "lineHeight": 1.55,
                    "color": "#1F1F1F",
                    "align": "left"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "education",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Education",
        "layout": "flow-vertical",
        "gap": 12,
        "visibleIf": "education",
        "children": [
          {
            "id": "education-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "# education",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 600,
              "fontSize": 12,
              "lineHeight": 1.3,
              "color": "#2F855A",
              "align": "left"
            }
          },
          {
            "id": "education-list",
            "type": "repeater",
            "x": 0, "y": 0,
            "bind": "education",
            "layout": "flow-vertical",
            "gap": 10,
            "template": {
              "id": "education-item",
              "type": "section",
              "x": 0, "y": 0,
              "layout": "flow-horizontal",
              "justify": "between",
              "align": "baseline",
              "gap": 12,
              "children": [
                {
                  "id": "education-item-left",
                  "type": "section",
                  "x": 0, "y": 0,
                  "layout": "flow-vertical",
                  "gap": 2,
                  "children": [
                    {
                      "id": "education-item-institution",
                      "type": "placeholder-text",
                      "x": 0, "y": 0,
                      "bind": "institution",
                      "fallback": "Institution",
                      "style": {
                        "fontFamily": "IBM Plex Sans",
                        "fontWeight": 600,
                        "fontSize": 12,
                        "lineHeight": 1.3,
                        "color": "#111111",
                        "align": "left"
                      }
                    },
                    {
                      "id": "education-item-degree",
                      "type": "text",
                      "x": 0, "y": 0,
                      "content": "{{degree}}, {{field}}",
                      "style": {
                        "fontFamily": "IBM Plex Sans",
                        "fontWeight": 400,
                        "fontSize": 11,
                        "lineHeight": 1.4,
                        "color": "#3F3F3F",
                        "align": "left"
                      }
                    }
                  ]
                },
                {
                  "id": "education-item-dates",
                  "type": "text",
                  "x": 0, "y": 0,
                  "content": "[{{startYear}} → {{endYear}}]",
                  "style": {
                    "fontFamily": "JetBrains Mono",
                    "fontWeight": 400,
                    "fontSize": 10.5,
                    "lineHeight": 1.3,
                    "color": "#2F855A",
                    "align": "right"
                  }
                }
              ]
            }
          }
        ]
      },

      {
        "id": "skills",
        "type": "section",
        "x": 0, "y": 0,
        "label": "Skills",
        "layout": "flow-vertical",
        "gap": 10,
        "visibleIf": "skills",
        "children": [
          {
            "id": "skills-title",
            "type": "text",
            "x": 0, "y": 0,
            "content": "# skills",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 600,
              "fontSize": 12,
              "lineHeight": 1.3,
              "color": "#2F855A",
              "align": "left"
            }
          },
          {
            "id": "skills-body",
            "type": "bullet-list",
            "x": 0, "y": 0,
            "bind": "skills",
            "layout": "inline",
            "bulletChar": "  ·  ",
            "style": {
              "fontFamily": "JetBrains Mono",
              "fontWeight": 400,
              "fontSize": 11,
              "lineHeight": 1.65,
              "color": "#1F1F1F",
              "align": "left"
            }
          }
        ]
      }
    ]
  }
}
