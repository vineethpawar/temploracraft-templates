{
  "name": "temploracraft-templates-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the temploracraft template marketplace.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@temploracraft/templates",
    "check-types": "npm run check-types --workspaces --if-present",
    "validate": "node scripts/validate.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
